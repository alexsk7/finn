#!/usr/bin/env bash
set -euo pipefail

repo_root="$(git rev-parse --show-toplevel)"
cd "$repo_root"

zero_sha="0000000000000000000000000000000000000000"

echo "Running pre-push checks with coverage..."
make coverage

echo "Generating coverage web report..."
mise exec -- uv run coverage html -d htmlcov >/dev/null
mise exec -- uv run python tests/coverage_dashboard.py

# Best-effort browser open; do not fail push if this cannot open.
if ! mise exec -- uv run python -c "from pathlib import Path; import webbrowser; webbrowser.open(Path('htmlcov/dashboard.html').resolve().as_uri())" >/dev/null 2>&1; then
	echo "Note: could not auto-open coverage dashboard."
fi

echo "Checking new-code coverage threshold (>= 80%)..."

checked_any=0

while read -r local_ref local_sha remote_ref remote_sha; do
	# Deleting a remote ref: nothing to test.
	if [[ "$local_sha" == "$zero_sha" ]]; then
		continue
	fi

	if [[ "$remote_sha" == "$zero_sha" ]]; then
		# New remote branch/tag. Compare against origin/main if available.
		if git rev-parse --verify origin/main >/dev/null 2>&1; then
			base_sha="$(git merge-base "$local_sha" origin/main)"
		else
			base_sha="$(git rev-list --max-parents=0 "$local_sha" | tail -1)"
		fi
	else
		# Existing ref update: only commits not yet on remote ref.
		base_sha="$remote_sha"
	fi

	echo "  Range: $base_sha..$local_sha ($local_ref -> $remote_ref)"
	mise exec -- uv run python scripts/check_new_code_coverage.py --base "$base_sha" --head "$local_sha" --threshold 80
	checked_any=1
done

if [[ "$checked_any" -eq 0 ]]; then
	echo "No updated refs with local commits to check."
fi